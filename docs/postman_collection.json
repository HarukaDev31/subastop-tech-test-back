{
  "info": {
    "name": "SWAPI Laravel API",
    "description": "API REST que integra la Star Wars API (SWAPI) con caché Redis, reintentos y DTOs mapeados al español. Gestiona planetas y habitantes localmente.\n\n## Autenticación\nTodas las rutas requieren el header `X-API-KEY`. Configura la variable `api_key` en el environment.\n\n## Base URL\nLocal: `http://localhost:8000/api`\nDocker: `http://localhost:8000/api`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string",
      "description": "URL base de la API"
    },
    {
      "key": "api_key",
      "value": "changeme-local-dev",
      "type": "string",
      "description": "Valor de API_KEY en tu .env"
    }
  ],
  "item": [
    {
      "name": "SWAPI – Personajes",
      "item": [
        {
          "name": "Listar personajes (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/swapi/personajes?pagina=1",
              "host": ["{{base_url}}"],
              "path": ["swapi", "personajes"],
              "query": [{ "key": "pagina", "value": "1", "description": "Numero de pagina" }]
            },
            "description": "Lista paginada de personajes. Resultado cacheado 1 hora."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"total\": 82,\n  \"siguiente\": \"https://swapi.py4e.com/api/people/?page=2\",\n  \"anterior\": null,\n  \"datos\": [\n    {\n      \"nombre\": \"Luke Skywalker\",\n      \"altura\": \"172\",\n      \"peso\": \"77\",\n      \"color_cabello\": \"blond\",\n      \"color_piel\": \"fair\",\n      \"color_ojos\": \"blue\",\n      \"anio_nacimiento\": \"19BBY\",\n      \"genero\": \"male\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Obtener personaje por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/swapi/personajes/1",
              "host": ["{{base_url}}"],
              "path": ["swapi", "personajes", "1"]
            },
            "description": "Obtiene un personaje mapeado al espanol mediante DTO."
          },
          "response": [
            {
              "name": "200 OK – Luke Skywalker",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"datos\": {\n    \"nombre\": \"Luke Skywalker\",\n    \"altura\": \"172\",\n    \"peso\": \"77\",\n    \"color_cabello\": \"blond\",\n    \"color_piel\": \"fair\",\n    \"color_ojos\": \"blue\",\n    \"anio_nacimiento\": \"19BBY\",\n    \"genero\": \"male\",\n    \"mundo_natal\": \"https://swapi.py4e.com/api/planets/1/\",\n    \"peliculas\": [],\n    \"especies\": [],\n    \"vehiculos\": [],\n    \"naves\": [],\n    \"creado\": \"2014-12-09T13:50:51.644000Z\",\n    \"editado\": \"2014-12-20T21:17:56.891000Z\",\n    \"url\": \"https://swapi.py4e.com/api/people/1/\"\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Recurso no encontrado.\"\n}"
            }
          ]
        }
      ]
    },
