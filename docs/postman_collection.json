    {
      "name": "Planetas Locales (CRUD)",
      "item": [
        {
          "name": "Listar planetas locales",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/planetas",
              "host": ["{{base_url}}"],
              "path": ["planetas"],
              "query": [
                { "key": "nombre", "value": "tat", "description": "Filtro por nombre (LIKE)", "disabled": true },
                { "key": "clima", "value": "arido", "description": "Filtro por clima (LIKE)", "disabled": true },
                { "key": "terreno", "value": "desierto", "description": "Filtro por terreno (LIKE)", "disabled": true },
                { "key": "recientes", "value": "30", "description": "Ultimos N dias", "disabled": true }
              ]
            },
            "description": "Lista planetas con eager loading de habitantes. Soporta filtros por nombre, clima, terreno y recientes (dias)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"datos\": [\n    {\n      \"id\": 1,\n      \"nombre\": \"Tatooine\",\n      \"clima\": \"arido\",\n      \"terreno\": \"desierto\",\n      \"diametro\": 10465,\n      \"poblacion\": 200000,\n      \"periodo_rotacion\": 23,\n      \"periodo_orbital\": 304,\n      \"gravedad\": \"1 estandar\",\n      \"agua_superficial\": \"1\",\n      \"creado_en\": \"2025-03-11T00:00:00.000000Z\",\n      \"actualizado_en\": \"2025-03-11T00:00:00.000000Z\",\n      \"habitantes\": [\n        {\n          \"id\": 1,\n          \"nombre\": \"Luke Skywalker\",\n          \"genero\": \"masculino\",\n          \"altura_cm\": 172,\n          \"peso_kg\": 77\n        }\n      ]\n    }\n  ],\n  \"meta\": {\n    \"total\": 1,\n    \"por_pagina\": 15,\n    \"pagina_actual\": 1,\n    \"ultima_pagina\": 1\n  }\n}"
            }
          ]
        },
        {
          "name": "Crear planeta con habitantes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Tatooine\",\n  \"clima\": \"arido\",\n  \"terreno\": \"desierto\",\n  \"diametro\": 10465,\n  \"poblacion\": 200000,\n  \"periodo_rotacion\": 23,\n  \"periodo_orbital\": 304,\n  \"gravedad\": \"1 estandar\",\n  \"agua_superficial\": \"1\",\n  \"habitantes\": [\n    {\n      \"nombre\": \"Luke Skywalker\",\n      \"genero\": \"masculino\",\n      \"altura_cm\": 172,\n      \"peso_kg\": 77,\n      \"color_cabello\": \"rubio\",\n      \"color_ojos\": \"azul\",\n      \"anio_nacimiento\": \"19BBY\"\n    },\n    {\n      \"nombre\": \"C-3PO\",\n      \"genero\": \"n/a\",\n      \"altura_cm\": 167,\n      \"peso_kg\": 75,\n      \"color_cabello\": \"n/a\",\n      \"color_ojos\": \"amarillo\",\n      \"anio_nacimiento\": \"112BBY\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/planetas",
              "host": ["{{base_url}}"],
              "path": ["planetas"]
            },
            "description": "Crea un planeta con sus habitantes en una sola transaccion. El nombre debe ser unico."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"mensaje\": \"Planeta creado exitosamente.\",\n  \"datos\": {\n    \"id\": 1,\n    \"nombre\": \"Tatooine\",\n    \"clima\": \"arido\",\n    \"terreno\": \"desierto\",\n    \"diametro\": 10465,\n    \"poblacion\": 200000,\n    \"habitantes\": [\n      { \"id\": 1, \"nombre\": \"Luke Skywalker\", \"genero\": \"masculino\" },\n      { \"id\": 2, \"nombre\": \"C-3PO\", \"genero\": \"n/a\" }\n    ]\n  }\n}"
            },
            {
              "name": "422 Nombre duplicado",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"message\": \"Error de validacion.\",\n  \"errores\": {\n    \"nombre\": [\"El campo nombre ya ha sido tomado.\"]\n  }\n}"
            },
            {
              "name": "422 Nombre requerido",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"message\": \"Error de validacion.\",\n  \"errores\": {\n    \"nombre\": [\"El campo nombre es obligatorio.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Obtener planeta por ID (con habitantes)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/planetas/1",
              "host": ["{{base_url}}"],
              "path": ["planetas", "1"]
            },
            "description": "Incluye habitantes via eager loading (sin N+1)."
          }
        },
        {
          "name": "Actualizar planeta",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clima\": \"templado\",\n  \"poblacion\": 250000,\n  \"agua_superficial\": \"5\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/planetas/1",
              "host": ["{{base_url}}"],
              "path": ["planetas", "1"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"mensaje\": \"Planeta actualizado exitosamente.\",\n  \"datos\": {\n    \"id\": 1,\n    \"nombre\": \"Tatooine\",\n    \"clima\": \"templado\",\n    \"poblacion\": 250000\n  }\n}"
            }
          ]
        },
        {
          "name": "Eliminar planeta",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-API-KEY", "value": "{{api_key}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/planetas/1",
              "host": ["{{base_url}}"],
              "path": ["planetas", "1"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"mensaje\": \"Planeta eliminado exitosamente.\"\n}"
            }
          ]
        }
      ]
    },
